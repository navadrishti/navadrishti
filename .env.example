# ===========================================
# NAVDRISHTI ENVIRONMENT CONFIGURATION
# ===========================================
# Single comprehensive environment file for all configurations

# ===========================================
# APPLICATION CONFIGURATION
# ===========================================
NODE_ENV=development
APP_NAME=Navdrishti
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# ===========================================
# SUPABASE CONFIGURATION (Primary Database)
# ===========================================
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ===========================================
# AUTHENTICATION & SECURITY
# ===========================================
JWT_SECRET=your_jwt_secret_here_at_least_32_characters_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Session Configuration
SESSION_SECRET=your_session_secret_here_at_least_32_characters_long
SESSION_MAX_AGE=604800000
SESSION_SECURE=false
SESSION_SAME_SITE=lax

# Cron Jobs Security (Optional - for extra security on automated tasks)
CRON_SECRET=your_cron_secret_here_optional

# Security Settings
BCRYPT_SALT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ===========================================
# CLOUDINARY CONFIGURATION (Image Upload)
# ===========================================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset

# File Upload Settings
UPLOAD_MAX_SIZE=5242880
UPLOAD_ALLOWED_TYPES=jpg,jpeg,png,pdf,doc,docx,webp


# ===========================================
# ADMIN CONFIGURATION
# ===========================================
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_admin_password_here

# ===========================================
# CA CONSOLE CONFIGURATION
# ===========================================
CA_USERNAME=ca
CA_PASSWORD=your_ca_password_here
CA_MEMBERSHIP_NUMBER=123456


# ===========================================
# DONATION PAYMENT CONFIGURATION (RAZORPAY - OPTIONAL)
# ===========================================
# Keep these commented until donation flows are implemented
# NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
# RAZORPAY_KEY_SECRET=your_razorpay_secret_here
# RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# ===========================================
# VERIFICATION SYSTEM CONFIGURATION
# ===========================================
# Email & Phone Verification
ENABLE_EMAIL_VERIFICATION=true
ENABLE_PHONE_VERIFICATION=true
ENABLE_DOCUMENT_VERIFICATION=true

